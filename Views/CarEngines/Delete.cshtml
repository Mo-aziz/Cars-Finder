@model WebApplication3.DTOs.CarEngineDetailsDto
@{
    ViewData["Title"] = "Delete Car Engine";
}

<h2>Delete Car Engine Relationship</h2>

<p><strong>Are you sure you want to delete this relationship?</strong></p>

<div>
    <strong>Car:</strong> @Model.CarBrand @Model.CarModel<br />
    <strong>Engine:</strong> @Model.EngineType<br />
    <strong>Installation Date:</strong> @Model.InstallationDate.ToShortDateString()<br />
</div>

<form asp-action="Delete" asp-route-carId="@Model.CarId" asp-route-engineId="@Model.EngineId" style="margin-top: 20px;">
    <input type="hidden" name="carId" value="@Model.CarId" />
    <input type="hidden" name="engineId" value="@Model.EngineId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
