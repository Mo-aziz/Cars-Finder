@model WebApplication3.DTOs.CarEngineUpdateDto
@{
    ViewData["Title"] = "Edit Car Engine";
}

<h2>Edit Car Engine Relationship</h2>

<form asp-action="Edit" asp-route-carId="@ViewBag.CarId" asp-route-engineId="@ViewBag.EngineId">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    
    <div class="mb-3">
        <label asp-for="InstallationDate"></label>
        <input asp-for="InstallationDate" class="form-control" type="date" />
        <span asp-validation-for="InstallationDate" class="text-danger"></span>
    </div>

    <div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
