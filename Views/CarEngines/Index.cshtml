@model IEnumerable<WebApplication3.DTOs.CarEngineListDto>
@{
    ViewData["Title"] = "Car Engines";
}

<h2>Car Engines</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Relationship</a>
</p>

@if (Model.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Car</th>
                <th>Engine</th>
                <th>Installation Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.CarBrand @item.CarModel</td>
                    <td>@item.EngineType</td>
                    <td>@item.InstallationDate.ToShortDateString()</td>
                    <td>
                        <a asp-action="Details" asp-route-carId="@item.CarId" asp-route-engineId="@item.EngineId" class="btn btn-sm btn-primary">Details</a>
                        <a asp-action="Edit" asp-route-carId="@item.CarId" asp-route-engineId="@item.EngineId" class="btn btn-sm btn-primary">Edit</a>
                        <a asp-action="Delete" asp-route-carId="@item.CarId" asp-route-engineId="@item.EngineId" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No car-engine relationships found. <a asp-action="Create">Add a relationship</a></p>
}
