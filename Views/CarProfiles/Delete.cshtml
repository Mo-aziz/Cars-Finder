@model WebApplication3.DTOs.CarProfileDetailsDto
@{
    ViewData["Title"] = "Delete Car Profile";
}

<h2>Delete Car Profile</h2>

<p><strong>Are you sure you want to delete this car profile?</strong></p>

<div>
    <strong>ID:</strong> @Model.Id<br />
    <strong>Car:</strong> @Model.CarBrand @Model.CarModel<br />
    <strong>Color:</strong> @Model.Color<br />
    <strong>Price:</strong> $@Model.Price<br />
</div>

<form asp-action="Delete" style="margin-top: 20px;">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
