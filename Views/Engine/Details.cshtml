@model WebApplication3.DTOs.EngineDetailsDto
@{
    ViewData["Title"] = "Engine Details";
}

<h2>Engine Details</h2>

<div>
    <strong>ID:</strong> @Model.Id<br />
    <strong>Type:</strong> @Model.Type<br />
    <strong>HorsePower:</strong> @Model.HorsePower<br />
    <strong>Car Count:</strong> @Model.CarCount<br />
</div>

<div style="margin-top: 20px;">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
