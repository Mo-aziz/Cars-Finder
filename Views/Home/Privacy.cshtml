@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body p-5">
                    <h1 class="mb-4">Privacy Policy</h1>
                    <p class="text-muted">
                        Last updated: March 24, 2026
                    </p>
                    
                    <h5 class="mt-4">Information We Collect</h5>
                    <p>
                        This Car Management System collects and stores information about cars, engines, manufacturers, 
                        and their relationships. This data is used solely for managing your car inventory.
                    </p>
                    
                    <h5 class="mt-4">How We Use Your Information</h5>
                    <p>
                        The information collected is used to:
                    </p>
                    <ul>
                        <li>Manage and organize your car inventory</li>
                        <li>Track relationships between cars, engines, and manufacturers</li>
                        <li>Provide detailed reports and statistics</li>
                        <li>Maintain accurate records of your automotive data</li>
                    </ul>
                    
                    <h5 class="mt-4">Data Security</h5>
                    <p>
                        We implement appropriate security measures to protect your data. All database connections 
                        use secure authentication and data is stored in a protected database environment.
                    </p>
                    
                    <h5 class="mt-4">Contact Us</h5>
                    <p>
                        If you have any questions about this Privacy Policy or our data practices, 
                        please contact the system administrator.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
