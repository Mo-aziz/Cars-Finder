@model WebApplication3.DTOs.ManufacturerDetailsDto
@{
    ViewData["Title"] = "Delete Manufacturer";
}

<h2>Delete Manufacturer</h2>

<p><strong>Are you sure you want to delete this manufacturer?</strong></p>

<div>
    <strong>ID:</strong> @Model.Id<br />
    <strong>Name:</strong> @Model.Name<br />
    <strong>Country:</strong> @Model.Country<br />
</div>

<form asp-action="Delete" style="margin-top: 20px;">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
