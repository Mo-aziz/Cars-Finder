@model WebApplication3.DTOs.ManufacturerDetailsDto
@{
    ViewData["Title"] = "Manufacturer Details";
}

<h2>Manufacturer Details</h2>

<div>
    <strong>ID:</strong> @Model.Id<br />
    <strong>Name:</strong> @Model.Name<br />
    <strong>Country:</strong> @Model.Country<br />
    <strong>Car Count:</strong> @Model.CarCount<br />
</div>

<div style="margin-top: 20px;">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
