<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Car Management</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #f9f9f9; }
        nav { background-color: #333; }
        .navbar-brand { color: white !important; font-weight: bold; }
        a.nav-link { color: white !important; }
        a.nav-link:hover { color: #ddd !important; }
        .btn-primary { background-color: #0056b3; border-color: #0056b3; }
        .btn-primary:hover { background-color: #004085; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg" style="background-color: #333;">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                Car Management
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Car" asp-action="Index">Cars</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Engine" asp-action="Index">Engines</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Manufacturer" asp-action="Index">Manufacturers</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="CarProfiles" asp-action="Index">Car Profiles</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="CarEngines" asp-action="Index">Car Engines</a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/swagger">API</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container my-4">
        @RenderBody()
    </div>

    <footer class="border-top mt-5 py-3">
        <div class="container text-center text-muted">
            <small>&copy; 2026 - Car Management System</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
